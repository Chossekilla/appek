# 🔒 v2.6.0 SECURITY: admin/ ochrana
Options -Indexes

# Zakázat directory traversal pokus
<IfModule mod_rewrite.c>
  RewriteEngine On
  # 🏠 v3.0.417 — "landing-only" režim (viz api/.htaccess): apex appek.cz má marker
  #   .landing-only → /admin nevede na installer, ale na landing. Zákazníci beze změny.
  RewriteCond %{DOCUMENT_ROOT}/.landing-only -f
  RewriteRule .* /? [R=302,L]

  RewriteRule "(^|/)\." - [F]
</IfModule>

# Skrýt dotfiles (.htaccess, .installed, atd)
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# .bak / .old / .backup soubory nesmí být dostupné
<FilesMatch "\.(bak|old|backup|orig|swp)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
