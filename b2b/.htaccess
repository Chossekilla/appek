# 🔒 b2b/ ochrana
Options -Indexes

# 🏠 v3.0.417 — "landing-only" režim (viz api/.htaccess): apex appek.cz má marker
#   .landing-only → /b2b nevede na installer, ale na landing. Zákazníci beze změny.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{DOCUMENT_ROOT}/.landing-only -f
  RewriteRule .* /? [R=302,L]
</IfModule>

# Skrýt dotfiles
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>
