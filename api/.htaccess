# 🔒 v2.6.0 SECURITY: api/ ochrana
Options -Indexes

# 🏠 v3.0.417 — "landing-only" režim: instalace, která NENÍ app-shop (jen prodejní
#   landing — apex appek.cz), má v docrootu marker .landing-only. Pak /api NEpřesměrovává
#   na install.php (ošklivá „chyba"), ale čistě na landing. Zákazníci marker nemají →
#   beze změny. Marker je preservovaný v self-update, takže přežije deploye.
<IfModule mod_rewrite.c>
  RewriteEngine On
  # 🐛 v3.0.427 — landing-only nesmí přesměrovat VEŘEJNÉ sales/landing endpointy,
  #   které prodejní stránka + checkout na apexu reálně potřebují (jinak „Nelze
  #   načíst balíčky"). Ostatní /api (install/admin/b2b/...) zůstává skryté.
  RewriteCond %{DOCUMENT_ROOT}/.landing-only -f
  RewriteCond %{REQUEST_URI} !/(shop_packages|shop_buy|shop_status|stripe_init|stripe_payment_intent|gopay_init|business_info|contact|css|updates_check|updates_download)\.php$
  RewriteRule .* /? [R=302,L]
</IfModule>

# Skrýt dotfiles
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Skrýt config.local.php (obsahuje DB password)
<FilesMatch "^(config\.local\.php|_pohoda\.php|_flexibee\.php|_customer_integrace\.php)$">
  # Tyto soubory jsou JEN required z PHP, nikdy přímo HTTP requestem
  # Pokud někdo přijde s ?file=config.local.php nebo přímou cestou:
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# _* lib soubory (PHP includes) — nesmí být přímý HTTP
<FilesMatch "^_">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Skrýt logy + zálohy + temp
<FilesMatch "\.(log|sql|backup|bak|old)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
