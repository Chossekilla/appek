# 🗺️ Floor Plan — Apache config pro subfolder
# Zajistí že `/floorplan/` vrátí index.php (ne 404)

Options -Indexes
<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

DirectoryIndex index.php index.html

<IfModule mod_mime.c>
  AddType application/x-httpd-php .php
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
